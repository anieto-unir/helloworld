pipeline {
    agent none

    options {
        skipDefaultCheckout true
    }

    stages {
        stage('Get Code') {
            agent any
            steps {
                // Obtener código del repo
                git 'https://github.com/gCuadros/helloworld-devops.git'
                sh 'ls -la'
                echo WORKSPACE
                stash includes: '**', name: 'code'
            }
        }

        stage('Build') {
            agent any
            steps {
                echo 'Eyyy, esto es Python. No hay que compilar nada!!!'
            }
        }

        stage('Tests') {
            parallel {
                stage('Unit') {
                    agent { label 'agent1' }
                    steps {
                        unstash 'code'
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                export PYTHONPATH=$WORKSPACE
                                python3 -m venv venv
                                . venv/bin/activate
                                pip install -r requirements.txt
                                pip install -e .
                                pytest --junitxml=result-unit.xml test/unit
                            '''
                        }
                        stash includes: 'result-unit.xml', name: 'unit-results'
                    }
                }

                stage('Rest') {
                    agent { label 'agent2' }
                    steps {
                        unstash 'code'
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                python3 -m venv venv
                                . venv/bin/activate
                                pip install -r requirements.txt
                                pip install -e .

                                export FLASK_APP=app/api.py

                                # Iniciar Flask en background
                                nohup flask run --port 5001 > flask.log 2>&1 &
                                echo $! > flask.pid
                                sleep 4

                                # Descargar Wiremock si no existe
                                if [ ! -f "wiremock-standalone.jar" ]; then
                                    echo "Downloading Wiremock..."
                                    curl -o wiremock-standalone.jar https://repo1.maven.org/maven2/com/github/tomakehurst/wiremock-standalone/2.27.2/wiremock-standalone-2.27.2.jar
                                fi
                                nohup java -jar wiremock-standalone.jar --port 9090 --root-dir test/wiremock > wiremock.log 2>&1 &
                                echo $! > wiremock.pid

                                echo "Waiting for services to start..."
                                sleep 10

                                # Ejecutar tests REST
                                pytest --junitxml=result-rest.xml test/rest

                                # Limpiar servicios
                                kill $(cat flask.pid) 2>/dev/null || true
                                kill $(cat wiremock.pid) 2>/dev/null || true
                            '''
                        }
                        stash includes: 'result-rest.xml', name: 'rest-results'
                    }
                }
            }
        }

        stage('Results') {
            agent any
            steps {
                unstash 'unit-results'
                unstash 'rest-results'
                junit 'result*.xml'
            }
        }
    }

    post {
        success {
            echo '========================================='
            echo 'Pipeline executed successfully!'
            echo 'All tests passed on distributed agents!'
            echo '========================================='
        }
        failure {
            echo '========================================='
            echo 'Pipeline failed!'
            echo 'Check logs above for details'
            echo '========================================='
        }
    }
}
